---
import BaseLayout from "@layouts/BaseLayout.astro";
import PostCardHero from "@components/cards/PostCardHero.astro";
import PostCardLarge from "@components/cards/PostCardLarge.astro";
import PostCardMedium from "@components/cards/PostCardMedium.astro";
import PostCardSmall from "@components/cards/PostCardSmall.astro";
import PostCardList from "@components/cards/PostCardList.astro";
import CategoryCard from "@components/cards/CategoryCard.astro";
import NewsTickerItem from "@components/cards/NewsTickerItem.astro";
import EmptyState from "@components/ui/EmptyState.astro";
import JsonLd from "@components/seo/JsonLd.astro";
import Toast from "@components/ui/Toast.astro";
import { getHome } from "@lib/wp/queries";
import type { HomeData } from "@lib/wp/queries";
import { siteUrl } from "@lib/wp/url";
import { ArrowRight, Mail } from "@lucide/astro";

let data: HomeData | null = null;
let error: string | null = null;
try {
  data = await getHome();
} catch (e) {
  error = (e as Error).message;
}

const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME ?? "Insight Lawyer";
const SITE_URL = (import.meta.env.PUBLIC_SITE_URL ?? "https://insightlawyer.in").replace(/\/$/, "");
const TAGLINE = import.meta.env.PUBLIC_SITE_TAGLINE ?? "Indian law, clearly explained.";

const latest = data?.latest?.nodes ?? [];
const news = data?.news?.nodes ?? [];
const editorPicks = data?.editorPicks?.nodes ?? [];
const practiceAreas = data?.practiceAreas?.nodes ?? [];

const hero = latest[0];
const secondaries = latest.slice(1, 3).filter(Boolean);
const tickerItems = news.slice(0, 6);
const remainingLatest = latest.slice(3, 13);

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: SITE_URL,
  description: TAGLINE,
  potentialAction: {
    "@type": "SearchAction",
    target: `${SITE_URL}/search?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE_NAME,
  url: SITE_URL,
  logo: `${SITE_URL}/icons/icon-512.png`,
  sameAs: [],
};
---
<BaseLayout
  title={SITE_NAME}
  description={TAGLINE}
  type="website"
>
  {error && !hero && (
    <div class="container-wide pt-12">
      <EmptyState
        title="The newsroom is taking a moment"
        description="We could not reach the editorial server. Please refresh in a few seconds."
      />
    </div>
  )}

  {/* News ticker */}
  {tickerItems.length > 0 && (
    <div class="border-b border-(--color-ink-200) bg-(--color-paper-2)">
      <div class="container-wide py-2">
        <div class="ticker">
          <div class="ticker__track">
            {[...tickerItems, ...tickerItems].map((p, i) => (
              <NewsTickerItem post={p} asNews={true} />
            ))}
          </div>
        </div>
      </div>
    </div>
  )}

  {/* Hero */}
  {hero && (
    <section class="container-wide pt-8 md:pt-14">
      <PostCardHero post={hero} />

      {secondaries.length > 0 && (
        <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-8 lg:gap-10 pt-10 border-t border-(--color-ink-200)">
          {secondaries.map((p) => p && <PostCardLarge post={p} />)}
        </div>
      )}
    </section>
  )}

  {/* Latest rail */}
  {remainingLatest.length > 0 && (
    <section class="container-wide mt-20 md:mt-28">
      <div class="flex items-end justify-between mb-8 md:mb-10">
        <div>
          <div class="section-eyebrow"><span class="kicker-dot">The Brief</span></div>
          <h2 class="font-serif text-3xl md:text-[2.5rem] font-semibold text-(--color-ink-900) tracking-[-0.02em] leading-tight">Latest</h2>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-sans font-semibold text-(--color-brand-700) hover:gap-2.5 transition-all duration-200">
          All articles <ArrowRight class="w-4 h-4" />
        </a>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12">
        <div class="lg:col-span-8 space-y-0">
          {remainingLatest.slice(0, 4).map((p, i) => (
            <PostCardList post={p} index={i + 1} />
          ))}
        </div>
        <div class="lg:col-span-4 space-y-6">
          <h3 class="kicker-dot mb-2">Most read</h3>
          {remainingLatest.slice(4, 9).map((p) => (
            <PostCardSmall post={p} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Practice areas */}
  {practiceAreas.length > 0 && (
    <section class="container-wide mt-20 md:mt-28">
      <div class="mb-8 md:mb-10">
        <div class="section-eyebrow"><span class="kicker-dot">By practice area</span></div>
        <h2 class="font-serif text-3xl md:text-[2.5rem] font-semibold text-(--color-ink-900) tracking-[-0.02em] leading-tight">Sections</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-5">
        {practiceAreas.slice(0, 8).map((c) => (
          <CategoryCard category={c} latest={latest.find((p) => p.categories?.nodes?.some((pc) => pc.slug === c.slug))} />
        ))}
      </div>
    </section>
  )}

  {/* From the bench (news) */}
  {news.length > 0 && (
    <section class="mt-20 md:mt-28">
      <div class="container-wide">
        <div class="flex items-end justify-between mb-8 md:mb-10">
          <div>
            <div class="section-eyebrow">
              <span class="kicker-dot text-(--color-danger)" style="--tw-text-opacity:1;">
                <span style="background-color: var(--color-danger);" class="inline-block w-1.5 h-1.5 rounded-full animate-pulse"></span>
                Live wire
              </span>
            </div>
            <h2 class="font-serif text-3xl md:text-[2.5rem] font-semibold text-(--color-ink-900) tracking-[-0.02em] leading-tight">From the bench</h2>
          </div>
          <a href="/news" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-sans font-semibold text-(--color-brand-700) hover:gap-2.5 transition-all duration-200">
            All news <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
      {/* Horizontal snap on mobile, grid on desktop */}
      <div class="md:hidden">
        <div class="h-snap px-5">
          {news.slice(0, 6).map((n) => (
            <div class="w-72">
              <PostCardMedium post={n} />
            </div>
          ))}
        </div>
      </div>
      <div class="container-wide hidden md:grid grid-cols-4 gap-7">
        {news.slice(0, 4).map((n) => <PostCardMedium post={n} />)}
      </div>
    </section>
  )}

  {/* Editor's picks */}
  {editorPicks.length > 0 && (
    <section class="container-wide mt-20 md:mt-28">
      <div class="mb-8 md:mb-10">
        <div class="section-eyebrow"><span class="kicker-dot">From the editors</span></div>
        <h2 class="font-serif text-3xl md:text-[2.5rem] font-semibold text-(--color-ink-900) tracking-[-0.02em] leading-tight">Editor’s picks</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
        {editorPicks.slice(0, 6).map((p) => <PostCardLarge post={p} />)}
      </div>
    </section>
  )}

  {/* Newsletter — modern CTA card */}
  <section class="container-wide mt-24 md:mt-32">
    <div class="card-cta px-6 py-12 md:px-16 md:py-16 max-w-4xl mx-auto">
      <div class="relative flex flex-col items-center text-center">
        <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-(--color-brand-700) text-(--color-gold-300) mb-6 ring-1 ring-(--color-brand-800)/40">
          <Mail class="w-5 h-5" />
        </span>
        <span class="kicker-dot mb-3">Newsletter</span>
        <h2 class="font-serif text-3xl md:text-[2.5rem] font-semibold text-(--color-ink-900) tracking-[-0.02em] leading-[1.1]">The Insight brief</h2>
        <p class="mt-4 text-(--color-ink-600) max-w-xl text-base md:text-lg leading-relaxed">A weekly digest of the most important Indian legal developments. Free, no spam, unsubscribe in one click.</p>
        <form action="/api/subscribe" method="post" class="mt-8 w-full max-w-md flex flex-col sm:flex-row gap-2">
          <input
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            class="flex-1 px-4 py-3.5 rounded-md border border-(--color-ink-200) bg-(--color-paper) font-sans text-base text-(--color-ink-900) placeholder:text-(--color-ink-400) focus:outline-2 focus:outline-(--color-brand-500) focus:border-(--color-brand-500) transition-colors"
            aria-label="Email address"
          />
          <button type="submit" class="tap px-6 py-3.5 rounded-md bg-(--color-brand-700) text-(--color-paper) font-sans font-semibold hover:bg-(--color-brand-800) transition-colors whitespace-nowrap">
            Subscribe
          </button>
        </form>
        <p class="mt-4 text-xs font-sans text-(--color-ink-500)">Join 4,200+ legal professionals.</p>
      </div>
    </div>
  </section>

  <Toast />

  <JsonLd data={[websiteSchema, orgSchema]} />
</BaseLayout>
