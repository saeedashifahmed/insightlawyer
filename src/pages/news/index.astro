---
import ArchiveLayout from "@layouts/ArchiveLayout.astro";
import PostCardMedium from "@components/cards/PostCardMedium.astro";
import EmptyState from "@components/ui/EmptyState.astro";
import { getNewsPage } from "@lib/wp/queries";

let news: Awaited<ReturnType<typeof getNewsPage>>["posts"] | null = null;
try {
  const data = await getNewsPage(24);
  news = data.posts;
} catch {
  news = null;
}
const items = news?.nodes ?? [];

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "News" },
];
---
<ArchiveLayout
  title="Live news wire"
  kicker="From the bench"
  description="Up-to-the-hour coverage of judgments, legislation, and the legal profession across India."
  breadcrumbs={breadcrumbs}
>
  {items.length > 0 ? (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {items.map((p) => <PostCardMedium post={p} />)}
    </div>
  ) : (
    <EmptyState title="No news yet" description="Check back shortly — the wire updates throughout the day." />
  )}
</ArchiveLayout>
