---
import BaseLayout from "@layouts/BaseLayout.astro";
import { ArrowLeft, Search as SearchIcon } from "@lucide/astro";
---
<BaseLayout title="Page not found — Insight Lawyer" noindex={true}>
  <section class="container-wide pt-12 md:pt-24 pb-20 text-center">
    <p class="kicker">Error 404</p>
    <h1 class="mt-2 font-serif text-5xl md:text-7xl font-semibold text-(--color-ink-900) leading-none">Not in our archive</h1>
    <p class="mt-6 max-w-prose mx-auto text-(--color-ink-600) text-lg">
      The page you’re looking for has moved, been retired, or never existed. Try searching, or head back to the home page.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/" class="tap inline-flex items-center gap-2 px-5 py-3 rounded-md bg-(--color-brand-500) text-(--color-paper) font-semibold">
        <ArrowLeft class="w-4 h-4" /> Home
      </a>
      <a href="/search" class="tap inline-flex items-center gap-2 px-5 py-3 rounded-md border border-(--color-ink-300) text-(--color-ink-900) font-semibold">
        <SearchIcon class="w-4 h-4" /> Search
      </a>
    </div>
  </section>
</BaseLayout>
