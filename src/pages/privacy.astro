---
import PageLayout from "@layouts/PageLayout.astro";
import { getPageBySlug } from "@lib/wp/queries";
import { enhanceWpHtml } from "@lib/wp/enhance-html";

let html = "";
let title = "Privacy policy";
try {
  const r = await getPageBySlug("privacy-policy");
  if (r.page) {
    title = r.page.title || title;
    html = await enhanceWpHtml(r.page.content ?? "");
  }
} catch { /* fallback */ }
---
<PageLayout title={title} breadcrumbs={[{ label: "Home", href: "/" }, { label: "Privacy" }]}>
  {html ? (
    <Fragment set:html={html} />
  ) : (
    <>
      <p>This policy describes how Insight Lawyer collects, uses, and protects your personal information.</p>
      <h2>What we collect</h2>
      <p>We collect minimal information: server logs (IP, user agent), the email you provide if you subscribe to the newsletter, and analytics events that do not contain personally identifying data.</p>
      <h2>How we use it</h2>
      <p>We use it to deliver the newsletter, debug technical problems, and understand which content readers find useful.</p>
      <h2>Cookies</h2>
      <p>We use only essential cookies and a single, anonymous analytics cookie. We do not run third-party advertising trackers.</p>
      <h2>Your rights</h2>
      <p>You can unsubscribe from email at any time. To request deletion of any data we hold, contact <a href="mailto:privacy@insightlawyer.in">privacy@insightlawyer.in</a>.</p>
    </>
  )}
</PageLayout>
