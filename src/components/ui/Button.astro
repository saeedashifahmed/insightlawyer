---
import { cn } from "@lib/utils/cn";

interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary" | "ghost" | "outline";
  size?: "sm" | "md" | "lg";
  fullWidth?: boolean;
  disabled?: boolean;
  class?: string;
  ariaLabel?: string;
  download?: boolean | string;
  rel?: string;
  target?: string;
  id?: string;
}

const {
  href,
  type = "button",
  variant = "primary",
  size = "md",
  fullWidth = false,
  disabled = false,
  class: cls,
  ariaLabel,
  download,
  rel,
  target,
  id,
} = Astro.props as Props;

const base =
  "tap inline-flex items-center justify-center gap-2 font-sans font-semibold rounded-md transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand-500) disabled:opacity-50 disabled:pointer-events-none";

const sizes = {
  sm: "text-sm px-3 py-1.5 min-h-9",
  md: "text-[0.94rem] px-4 py-2.5 min-h-11",
  lg: "text-base px-5 py-3 min-h-12",
};

const variants = {
  primary: "bg-(--color-brand-500) text-(--color-paper) hover:bg-(--color-brand-600) shadow-[var(--shadow-card)]",
  secondary: "bg-(--color-ink-900) text-(--color-paper) hover:bg-(--color-ink-700)",
  ghost: "bg-transparent text-(--color-ink-700) hover:bg-(--color-ink-100)",
  outline: "bg-transparent text-(--color-ink-900) border border-(--color-ink-300) hover:border-(--color-ink-500) hover:bg-(--color-paper-2)",
};

const className = cn(base, sizes[size], variants[variant], fullWidth && "w-full", cls);
---
{href ? (
  <a
    href={href}
    class={className}
    aria-label={ariaLabel}
    download={download as never}
    rel={rel}
    target={target}
    id={id}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    class={className}
    disabled={disabled}
    aria-label={ariaLabel}
    id={id}
  >
    <slot />
  </button>
)}
