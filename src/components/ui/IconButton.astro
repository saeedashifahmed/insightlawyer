---
import { cn } from "@lib/utils/cn";

interface Props {
  href?: string;
  type?: "button" | "submit";
  size?: "sm" | "md" | "lg";
  variant?: "ghost" | "solid" | "outline";
  ariaLabel: string;
  class?: string;
  id?: string;
  rel?: string;
  target?: string;
}

const {
  href,
  type = "button",
  size = "md",
  variant = "ghost",
  ariaLabel,
  class: cls,
  id,
  rel,
  target,
} = Astro.props as Props;

const sizes = {
  sm: "w-9 h-9",
  md: "w-11 h-11",
  lg: "w-12 h-12",
};
const variants = {
  ghost: "text-(--color-ink-700) hover:bg-(--color-ink-100)",
  solid: "bg-(--color-ink-900) text-(--color-paper) hover:bg-(--color-ink-700)",
  outline: "border border-(--color-ink-300) text-(--color-ink-700) hover:border-(--color-ink-500)",
};

const cn1 = cn(
  "tap inline-flex items-center justify-center rounded-full transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand-500)",
  sizes[size],
  variants[variant],
  cls,
);
---
{href ? (
  <a href={href} class={cn1} aria-label={ariaLabel} id={id} rel={rel} target={target}><slot /></a>
) : (
  <button type={type} class={cn1} aria-label={ariaLabel} id={id}><slot /></button>
)}
