---
import { Search, Menu, Sun, Moon, Bookmark } from "@lucide/astro";
import IconButton from "@components/ui/IconButton.astro";
import HeaderSearch from "./HeaderSearch.astro";

const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME ?? "Insight Lawyer";

// Top-level nav. We keep this static and editorial — categories live here,
// not the entire WP menu. Replace at will if WP menu is preferred.
const NAV = [
  { label: "Home", href: "/" },
  { label: "News", href: "/news" },
  { label: "Supreme Court", href: "/category/supreme-court" },
  { label: "High Court", href: "/category/high-court" },
  { label: "Editorials", href: "/category/editorials" },
  { label: "Featured", href: "/category/featured-stories" },
  { label: "About", href: "/about" },
];

const path = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(`${href}/`);
}
---
<header
  id="il-header"
  class="auto-hide sticky top-0 z-50 bg-(--color-paper)/85 backdrop-blur supports-[backdrop-filter]:bg-(--color-paper)/75 border-b border-(--color-ink-200)"
>
  <div class="container-wide flex items-center justify-between h-16">
    {/* Mobile menu */}
    <IconButton ariaLabel="Open menu" class="md:hidden -ml-2" id="il-drawer-open">
      <Menu class="w-5 h-5" />
    </IconButton>

    {/* Logo — masthead style: serif IL mark + wordmark with kicker tagline */}
    <a href="/" class="tap inline-flex items-center gap-3" aria-label={SITE_NAME} transition:name="site-logo">
      <span class="relative inline-flex flex-col items-center justify-center w-10 h-10 rounded-sm bg-(--color-brand-700) ring-1 ring-(--color-brand-800)/40">
        <span class="font-serif font-semibold text-(--color-gold-300) text-[15px] leading-none tracking-[0.02em] -mb-1">IL</span>
        <span class="absolute bottom-1.5 left-1/2 -translate-x-1/2 w-3 h-px bg-(--color-gold-400)"></span>
      </span>
      <span class="hidden sm:inline-flex flex-col leading-none">
        <span class="font-serif text-[19px] font-semibold text-(--color-ink-900) tracking-tight">Insight Lawyer</span>
        <span class="mt-1 font-sans text-[9px] uppercase tracking-[0.22em] text-(--color-ink-500) font-medium">Indian Legal Journal</span>
      </span>
    </a>

    {/* Desktop nav */}
    <nav class="hidden md:flex items-center gap-7 text-[0.92rem] font-sans" aria-label="Primary">
      {NAV.map((n) => (
        <a
          href={n.href}
          class={`nav-link ${
            isActive(n.href)
              ? "text-(--color-ink-900) font-semibold"
              : "text-(--color-ink-600) hover:text-(--color-ink-900)"
          }`}
          aria-current={isActive(n.href) ? "page" : undefined}
        >
          {n.label}
        </a>
      ))}
    </nav>

    {/* Right cluster */}
    <div class="flex items-center gap-1">
      <IconButton ariaLabel="Search" id="il-search-open">
        <Search class="w-5 h-5" />
      </IconButton>
      <IconButton ariaLabel="Saved articles" href="/saved" class="hidden md:inline-flex">
        <Bookmark class="w-5 h-5" />
      </IconButton>
      <IconButton ariaLabel="Toggle theme" id="il-theme-toggle" class="hidden md:inline-flex">
        <Sun class="w-5 h-5 hidden dark:block" />
        <Moon class="w-5 h-5 dark:hidden" />
      </IconButton>
    </div>
  </div>

  <HeaderSearch />
</header>

<script>
  // Auto-hide on scroll-down, slide-in on scroll-up
  const header = document.getElementById("il-header");
  if (header) {
    let last = 0;
    let raf = 0;
    const onScroll = () => {
      raf = 0;
      const y = window.scrollY;
      const goingDown = y > last && y > 80;
      header.dataset.hidden = goingDown ? "true" : "false";
      header.dataset.compact = y > 80 ? "true" : "false";
      last = y;
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!raf) raf = requestAnimationFrame(onScroll);
      },
      { passive: true },
    );
  }

  // Drawer open
  document.getElementById("il-drawer-open")?.addEventListener("click", () => {
    document.getElementById("il-drawer")?.setAttribute("data-open", "true");
    document.getElementById("il-drawer-backdrop")?.setAttribute("data-open", "true");
    document.body.style.overflow = "hidden";
  });

  // Search open (focus input)
  document.getElementById("il-search-open")?.addEventListener("click", () => {
    const panel = document.getElementById("il-search-panel");
    if (!panel) return;
    panel.dataset.open = panel.dataset.open === "true" ? "false" : "true";
    if (panel.dataset.open === "true") {
      setTimeout(() => panel.querySelector<HTMLInputElement>("input")?.focus(), 50);
    }
  });

  // Theme toggle
  document.getElementById("il-theme-toggle")?.addEventListener("click", () => {
    const root = document.documentElement;
    const isDark = root.classList.contains("dark");
    if (isDark) {
      root.classList.remove("dark");
      root.classList.add("light");
      localStorage.setItem("il-theme", "light");
    } else {
      root.classList.remove("light");
      root.classList.add("dark");
      localStorage.setItem("il-theme", "dark");
    }
  });
</script>

<style>
  #il-header[data-compact="true"] .h-16 { height: 3.25rem; }
</style>
