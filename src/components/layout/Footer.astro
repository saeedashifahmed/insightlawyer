---
const SITE_NAME = import.meta.env.PUBLIC_SITE_NAME ?? "Insight Lawyer";
const TAGLINE = import.meta.env.PUBLIC_SITE_TAGLINE ?? "Indian law, clearly explained.";
const year = new Date().getFullYear();

const SECTIONS = [
  { label: "Constitutional", href: "/category/constitutional" },
  { label: "Criminal", href: "/category/criminal" },
  { label: "Civil", href: "/category/civil" },
  { label: "Corporate", href: "/category/corporate" },
  { label: "Tax", href: "/category/tax" },
  { label: "Intellectual Property", href: "/category/ip" },
  { label: "Family", href: "/category/family" },
  { label: "Labor", href: "/category/labor" },
];
const ABOUT = [
  { label: "About Insight Lawyer", href: "/about" },
  { label: "Editorial standards", href: "/editorial-standards" },
  { label: "Contributors", href: "/author" },
  { label: "Contact", href: "/contact" },
  { label: "RSS Feed", href: "/rss.xml" },
];
const LEGAL = [
  { label: "Privacy policy", href: "/privacy" },
  { label: "Disclaimer", href: "/disclaimer" },
  { label: "Terms of use", href: "/terms" },
  { label: "Sitemap", href: "/sitemap.xml" },
];
---
<footer class="mt-20 bg-(--color-paper-2) border-t border-(--color-ink-200)">
  <div class="container-wide py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="relative inline-flex flex-col items-center justify-center w-11 h-11 rounded-sm bg-(--color-brand-700) ring-1 ring-(--color-brand-800)/40">
            <span class="font-serif font-semibold text-(--color-gold-300) text-base leading-none tracking-[0.02em] -mb-1">IL</span>
            <span class="absolute bottom-2 left-1/2 -translate-x-1/2 w-3.5 h-px bg-(--color-gold-400)"></span>
          </span>
          <span class="flex flex-col leading-none">
            <span class="font-serif text-xl font-semibold text-(--color-ink-900) tracking-tight">{SITE_NAME}</span>
            <span class="mt-1 font-sans text-[9px] uppercase tracking-[0.22em] text-(--color-ink-500) font-medium">Indian Legal Journal</span>
          </span>
        </div>
        <p class="font-serif italic text-(--color-ink-500) text-base">{TAGLINE}</p>
        <p class="mt-6 text-sm text-(--color-ink-600) max-w-xs leading-relaxed">
          A reader-supported publication covering the practice and theory of Indian law for lawyers, students, and informed citizens.
        </p>
      </div>

      <div class="md:col-span-3">
        <h3 class="kicker mb-4">Sections</h3>
        <ul class="space-y-2">
          {SECTIONS.map((s) => (
            <li>
              <a href={s.href} class="text-(--color-ink-700) hover:text-(--color-ink-900) text-[0.94rem]">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-3">
        <h3 class="kicker mb-4">About</h3>
        <ul class="space-y-2">
          {ABOUT.map((s) => (
            <li>
              <a href={s.href} class="text-(--color-ink-700) hover:text-(--color-ink-900) text-[0.94rem]">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <h3 class="kicker mb-4">Legal</h3>
        <ul class="space-y-2">
          {LEGAL.map((s) => (
            <li>
              <a href={s.href} class="text-(--color-ink-700) hover:text-(--color-ink-900) text-[0.94rem]">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-(--color-ink-200) flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <p class="text-xs text-(--color-ink-500) font-sans">
        &copy; {year} {SITE_NAME}. All rights reserved.
      </p>
      <p class="text-xs text-(--color-ink-500) font-sans max-w-xl md:text-right">
        Content on this site is for general informational purposes and does not constitute legal advice. Consult a qualified advocate for advice on a specific matter.
      </p>
    </div>
  </div>
</footer>
