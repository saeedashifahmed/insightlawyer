---
import type { WPPost } from "@lib/wp/types";
import { formatDateLong, isFresh } from "@lib/utils/date";
import { readingTimeMinutes } from "@lib/utils/reading-time";
import { cleanWpExcerpt, makeExcerpt } from "@lib/utils/excerpt";
import { postPath, categoryPath } from "@lib/wp/url";
import Badge from "@components/ui/Badge.astro";

interface Props {
  post: WPPost;
}

const { post } = Astro.props as Props;
const cat = post.categories?.nodes?.[0];
const img = post.featuredImage?.node;
const isLive = isFresh(post.date, 24);
const minutes = readingTimeMinutes(post.content ?? post.excerpt);
const deck = makeExcerpt(cleanWpExcerpt(post.excerpt) || post.content, 220);
---
<article class="group">
  <a
    href={postPath(post.slug)}
    class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center"
    transition:name={`post-${post.slug}`}
  >
    {img?.sourceUrl && (
      <div class="img-zoom relative lg:col-span-7 border border-(--color-ink-200) bg-(--color-paper-2) aspect-[16/10]" transition:name={`hero-${post.slug}`}>
        <img
          src={img.sourceUrl}
          alt={img.altText ?? post.title}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        {cat && (
          <div class="absolute top-4 left-4 z-10">
            <span class="pill-cat pill-cat-solid">{cat.name}</span>
          </div>
        )}
        {isLive && (
          <div class="absolute top-4 right-4 z-10">
            <Badge variant="live" size="md">Live</Badge>
          </div>
        )}
      </div>
    )}

    <div class="lg:col-span-5">
      {cat && (
        <span class="kicker-dot">{cat.name}</span>
      )}
      <h2 class="mt-4 font-serif text-[2rem] md:text-[2.6rem] lg:text-[3.4rem] font-semibold text-(--color-ink-900) leading-[1.02] tracking-[-0.02em] group-hover:text-(--color-brand-700) transition-colors duration-300" transition:name={`title-${post.slug}`}>
        {post.title}
      </h2>
      {deck && (
        <p class="mt-5 font-serif text-lg md:text-xl text-(--color-ink-600) leading-[1.45] max-w-prose">{deck}</p>
      )}
      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm font-sans text-(--color-ink-500)">
        {post.author?.node?.name && (
          <span class="text-(--color-ink-800) font-semibold">{post.author.node.name}</span>
        )}
        {post.date && <span class="meta-dot" aria-hidden="true"></span>}
        {post.date && <time datetime={post.date}>{formatDateLong(post.date)}</time>}
        <span class="meta-dot" aria-hidden="true"></span>
        <span>{minutes} min read</span>
      </div>
    </div>
  </a>
</article>
