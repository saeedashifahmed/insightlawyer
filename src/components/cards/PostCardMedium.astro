---
import type { WPPost } from "@lib/wp/types";
import { formatDateShort } from "@lib/utils/date";
import { readingTimeMinutes } from "@lib/utils/reading-time";
import { postPath } from "@lib/wp/url";

interface Props { post: WPPost; }
const { post } = Astro.props as Props;
const cat = post.categories?.nodes?.[0];
const img = post.featuredImage?.node;
const minutes = readingTimeMinutes(post.content ?? post.excerpt);
---
<article class="group card-lift">
  <a href={postPath(post.slug)} class="block">
    {img?.sourceUrl && (
      <div class="img-zoom border border-(--color-ink-200) bg-(--color-paper-2) aspect-[16/10]">
        <img
          src={img.sourceUrl}
          alt={img.altText ?? post.title}
          loading="lazy"
          decoding="async"
        />
      </div>
    )}
    <div class="mt-4">
      {cat && (
        <span class="kicker-dot">{cat.name}</span>
      )}
      <h3 class="mt-2 font-serif text-lg md:text-xl font-semibold text-(--color-ink-900) leading-snug group-hover:text-(--color-brand-700) transition-colors duration-300 line-clamp-3">
        {post.title}
      </h3>
      <div class="mt-3 flex items-center gap-2 text-xs font-sans text-(--color-ink-500)">
        {post.date && <time datetime={post.date}>{formatDateShort(post.date)}</time>}
        <span class="meta-dot" aria-hidden="true"></span>
        <span>{minutes} min read</span>
      </div>
    </div>
  </a>
</article>
