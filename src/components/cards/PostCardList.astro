---
import type { WPPost } from "@lib/wp/types";
import { formatDateShort } from "@lib/utils/date";
import { readingTimeMinutes } from "@lib/utils/reading-time";
import { postPath, categoryPath } from "@lib/wp/url";
import { cleanWpExcerpt, makeExcerpt } from "@lib/utils/excerpt";

interface Props { post: WPPost; index?: number; }
const { post, index } = Astro.props as Props;
const cat = post.categories?.nodes?.[0];
const minutes = readingTimeMinutes(post.content ?? post.excerpt);
const deck = makeExcerpt(cleanWpExcerpt(post.excerpt) || post.content, 200);
---
<article class="group flex items-start gap-6 py-6 border-b border-(--color-ink-200) last:border-b-0">
  {typeof index === "number" && (
    <div class="hidden md:block flex-none w-10 text-right font-serif text-3xl font-semibold text-(--color-ink-300) leading-none pt-1">
      {String(index).padStart(2, "0")}
    </div>
  )}
  <div class="flex-1 min-w-0">
    {cat && (
      <a href={categoryPath(cat.slug)} class="kicker hover:text-(--color-brand-700) transition-colors">{cat.name}</a>
    )}
    <a href={postPath(post.slug)} class="block">
      <h3 class="mt-2 font-serif text-xl md:text-2xl font-semibold text-(--color-ink-900) leading-snug group-hover:text-(--color-brand-600) transition-colors">
        {post.title}
      </h3>
      {deck && <p class="mt-2 text-(--color-ink-600) text-[0.96rem] leading-relaxed line-clamp-2">{deck}</p>}
    </a>
    <div class="mt-2 flex items-center gap-2 text-xs font-sans text-(--color-ink-500)">
      {post.author?.node?.name && <span class="text-(--color-ink-700) font-semibold">{post.author.node.name}</span>}
      {post.date && <span>·</span>}
      {post.date && <time datetime={post.date}>{formatDateShort(post.date)}</time>}
      <span>·</span>
      <span>{minutes} min</span>
    </div>
  </div>
  {post.featuredImage?.node?.sourceUrl && (
    <a href={postPath(post.slug)} class="flex-none w-32 h-32 md:w-40 md:h-28 overflow-hidden rounded-md border border-(--color-ink-200) bg-(--color-paper-2)">
      <img
        src={post.featuredImage.node.sourceUrl}
        alt={post.featuredImage.node.altText ?? post.title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
      />
    </a>
  )}
</article>
