---
import type { WPPost } from "@lib/wp/types";
import { formatDateShort } from "@lib/utils/date";
import { authorPath, categoryPath } from "@lib/wp/url";
import { Clock } from "@lucide/astro";

interface Props {
  post: WPPost;
  minutes?: number;
  compact?: boolean;
}
const { post, minutes = 5, compact = false } = Astro.props as Props;
const cat = post.categories?.nodes?.[0];
const author = post.author?.node;
---
<div class={`flex flex-wrap items-center gap-x-2 gap-y-1 text-${compact ? "xs" : "sm"} font-sans text-(--color-ink-500)`}>
  {cat && (
    <a href={categoryPath(cat.slug)} class="kicker hover:text-(--color-brand-700)">{cat.name}</a>
  )}
  {author && (
    <>
      <span aria-hidden="true">·</span>
      <a href={authorPath(author.slug)} class="text-(--color-ink-700) font-semibold hover:text-(--color-brand-600)">
        {author.name}
      </a>
    </>
  )}
  {post.date && (
    <>
      <span aria-hidden="true">·</span>
      <time datetime={post.date}>{formatDateShort(post.date)}</time>
    </>
  )}
  <span aria-hidden="true">·</span>
  <span class="inline-flex items-center gap-1">
    <Clock class="w-3 h-3" />
    {minutes} min
  </span>
</div>
