---
import { Mail, Link2, Share2, X } from "@lucide/astro";
import { shareLinks } from "@lib/utils/share";

interface Props { url: string; title: string; }
const { url, title } = Astro.props as Props;
const links = shareLinks({ url, title });

const ITEMS = [
  {
    label: "X (Twitter)",
    href: links.twitter,
    svg: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
  },
  {
    label: "LinkedIn",
    href: links.linkedin,
    svg: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    label: "WhatsApp",
    href: links.whatsapp,
    svg: `<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>`,
  },
  {
    label: "Facebook",
    href: links.facebook,
    svg: `<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>`,
  },
  {
    label: "Email",
    href: links.email,
    svg: null,
    lucideIcon: "Mail",
  },
];
---
<button
  type="button"
  data-sheet-open="il-share-sheet"
  aria-label="Share article"
  class="md:hidden tap fixed right-4 z-40 w-12 h-12 rounded-full bg-(--color-ink-900) text-(--color-paper) shadow-[var(--shadow-pop)] inline-flex items-center justify-center"
  style="bottom: calc(5.5rem + env(safe-area-inset-bottom)); opacity: 0; pointer-events: none; transition: opacity 200ms;"
  id="il-share-fab"
>
  <Share2 class="w-5 h-5" />
</button>

<div id="il-share-sheet-backdrop" class="sheet-backdrop"></div>
<div id="il-share-sheet" class="sheet md:hidden" role="dialog" aria-label="Share article">
  <div class="px-5 py-4 flex items-center justify-between border-b border-(--color-ink-200)">
    <h2 class="font-serif text-lg font-semibold text-(--color-ink-900)">Share this article</h2>
    <button type="button" data-sheet-close aria-label="Close" class="tap w-9 h-9 rounded-full inline-flex items-center justify-center hover:bg-(--color-ink-100)">
      <X class="w-5 h-5" />
    </button>
  </div>
  <div class="p-5 grid grid-cols-4 gap-4">
    {ITEMS.map(({ label, href, svg }) => (
      <a
        href={href}
        rel="noopener noreferrer"
        target="_blank"
        class="tap flex flex-col items-center gap-2 text-center"
      >
        <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-(--color-paper-2) text-(--color-ink-700)">
          {svg ? (
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={svg} />
          ) : (
            <Mail class="w-5 h-5" />
          )}
        </span>
        <span class="text-xs font-sans text-(--color-ink-700)">{label}</span>
      </a>
    ))}
    <button type="button" id="il-share-copy" class="tap flex flex-col items-center gap-2 text-center">
      <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-(--color-paper-2) text-(--color-ink-700)">
        <Link2 class="w-5 h-5" />
      </span>
      <span class="text-xs font-sans text-(--color-ink-700)">Copy link</span>
    </button>
  </div>

  <div class="px-5 pb-5 pt-1">
    <button
      type="button"
      id="il-share-native"
      class="tap w-full inline-flex items-center justify-center gap-2 px-4 py-3 rounded-md bg-(--color-brand-500) text-(--color-paper) font-semibold"
    >
      <Share2 class="w-4 h-4" /> More sharing options
    </button>
  </div>
</div>

<script define:vars={{ url, title }}>
  const fab = document.getElementById("il-share-fab");
  const native = document.getElementById("il-share-native");
  const copy = document.getElementById("il-share-copy");

  if (!navigator.share) native?.classList.add("hidden");

  native?.addEventListener("click", async () => {
    if (!navigator.share) return;
    try { await navigator.share({ url, title }); } catch { /* dismissed */ }
  });

  copy?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(url);
      window.dispatchEvent(new CustomEvent("il-toast", { detail: "Link copied" }));
    } catch {
      window.dispatchEvent(new CustomEvent("il-toast", { detail: "Could not copy" }));
    }
  });

  let raf = 0;
  const onScroll = () => {
    raf = 0;
    if (!fab) return;
    fab.style.opacity = window.scrollY > 200 ? "1" : "0";
    fab.style.pointerEvents = window.scrollY > 200 ? "auto" : "none";
  };
  if (fab) {
    window.addEventListener("scroll", () => { if (!raf) raf = requestAnimationFrame(onScroll); }, { passive: true });
  }
</script>
