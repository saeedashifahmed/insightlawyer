---
import type { WPTag } from "@lib/wp/types";
import { tagPath } from "@lib/wp/url";

interface Props { tags: WPTag[]; }
const { tags } = Astro.props as Props;
---
<div>
  <h3 class="kicker mb-3">Tagged</h3>
  <ul class="flex flex-wrap gap-2">
    {tags.map((t) => (
      <li>
        <a
          href={tagPath(t.slug)}
          class="tap inline-flex items-center px-3 py-1.5 rounded-full text-sm font-sans border border-(--color-ink-200) text-(--color-ink-700) hover:border-(--color-ink-500) hover:text-(--color-ink-900) transition-colors"
        >
          #{t.name}
        </a>
      </li>
    ))}
  </ul>
</div>
