{
  "name": "insightlawyer-web",
  "version": "1.0.0",
  "description": "Insight Lawyer — headless WordPress frontend for Indian legal editorial content. Astro 6.3 SSR + Tailwind v4.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "wrangler dev --config dist/server/wrangler.json",
    "deploy": "astro build && wrangler deploy --config dist/server/wrangler.json",
    "astro": "astro",
    "check": "astro check && tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,md,css,json}\"",
    "lint": "prettier --check \"src/**/*.{ts,tsx,astro,md,css,json}\""
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.0",
    "@astrojs/rss": "^4.0.10",
    "@astrojs/sitemap": "^3.2.1",
    "@fontsource-variable/fraunces": "^5.1.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.1.0",
    "@lucide/astro": "^1.14.0",
    "@tailwindcss/vite": "^4.2.0",
    "astro": "^6.3.0",
    "node-html-parser": "^7.0.1",
    "sanitize-html": "^2.13.1",
    "shiki": "^1.24.0",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/sanitize-html": "^2.13.0",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.0"
  }
}
